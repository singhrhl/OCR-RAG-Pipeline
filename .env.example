# ─────────────────────────────────────────────
# POPPLER_PATH — path to Poppler's `bin` folder
# Required by pdf2image for converting PDF pages to images.
# ─────────────────────────────────────────────
#
# Linux (Ubuntu/Debian):
#   sudo apt update && sudo apt install poppler-utils
#   Installs to a location already on PATH — leave POPPLER_PATH empty.
#
# macOS:
#   brew install poppler
#   Installs to a location already on PATH — leave POPPLER_PATH empty.
#
# Windows:
#   Download: https://github.com/oschwartz10612/poppler-windows/releases
#   Extract somewhere stable, e.g. C:\poppler
#   Set POPPLER_PATH below to the `bin` folder inside it, e.g.:
#   POPPLER_PATH=C:\poppler\Library\bin
#
# Leave this blank on Linux/macOS. Only Windows users need to set it.
POPPLER_PATH=